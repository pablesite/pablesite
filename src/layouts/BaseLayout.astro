---
import { localizePath, locales, nav, site, type Locale } from "@data/site";
import "@styles/global.css";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path?: string;
  alternatePath?: string;
}

const { title, description, locale, path = "", alternatePath } = Astro.props;
const canonical = new URL(`/${locale}/${path}`, site.baseUrl).toString();
const alternateLocale = locale === "es" ? "en" : "es";
const resolvedAlternatePath = alternatePath ?? `/${alternateLocale}/${path}`;
const localeLinks = locales.map((entry) => ({
  code: entry.toUpperCase(),
  href:
    entry === alternateLocale
      ? resolvedAlternatePath
      : localizePath(entry, path),
  isCurrent: entry === locale,
}));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      hreflang="es"
      href={new URL(`/es/${path}`, site.baseUrl)}
    />
    <link
      rel="alternate"
      hreflang="en"
      href={new URL(`/en/${path}`, site.baseUrl)}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(`/es/${path}`, site.baseUrl)}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(site.avatar, site.baseUrl)} />
    <link rel="icon" type="image/png" href={site.avatar} />
    <link rel="apple-touch-icon" href={site.avatar} />
    <meta name="theme-color" content="#080b10" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={`/${locale}/`} aria-label={site.name}>
          <img class="brand__avatar" src={site.avatar} alt="" />
          <span>{site.name}</span>
        </a>
        <div class="site-header__actions">
          <nav
            class="site-nav"
            aria-label={locale === "es"
              ? "Navegación principal"
              : "Main navigation"}
          >
            {
              nav[locale].map((item) => (
                <a href={item.href} class="site-nav__link">
                  {item.label}
                </a>
              ))
            }
          </nav>

          <div
            class="locale-switcher"
            role="group"
            aria-label={locale === "es"
              ? "Selector de idioma"
              : "Language selector"}
          >
            {
              localeLinks.map((entry) =>
                entry.isCurrent ? (
                  <span class="locale-switcher__option locale-switcher__option--active">
                    {entry.code}
                  </span>
                ) : (
                  <a
                    class="locale-switcher__option"
                    href={entry.href}
                    lang={entry.code.toLowerCase()}
                    hreflang={entry.code.toLowerCase()}
                  >
                    {entry.code}
                  </a>
                ),
              )
            }
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        {site.name} · {site.location[locale]} · © 2026
      </footer>
    </div>
  </body>
</html>
