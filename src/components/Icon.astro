    "M9 13 6.5 6H5",
  ],
  music: [
    "M9 18V5l12-2v13",
    "M9 18a3 3 0 1 1-3-3 3 3 0 0 1 3 3Z",
    "M21 16a3 3 0 1 1-3-3 3 3 0 0 1 3 3Z",
  ],
  book: [
    "M4 19.5A2.5 2.5 0 0 1 6.5 17H20",
    "M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5Z",
  ],
  server: ["M4 6h16v5H4z", "M4 13h16v5H4z", "M7 8.5h.01", "M7 15.5h.01"],
  cloud: [
