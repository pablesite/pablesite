---
import BlogList from "@components/BlogList.astro";
import MetaLabel from "@components/MetaLabel.astro";
import Section from "@components/Section.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedBlogPosts } from "@data/blog";

const locale = "en";
const posts = await getPublishedBlogPosts(locale);
---

<BaseLayout
  title="Blog — pablesite.es"
  description="Notes and lessons about Arda, The Arkenstone, agentic AI and self-hosted infrastructure."
  locale={locale}
  path="blog/"
>
  <a class="back-link" href="/en/">← pablesite.es</a>
  <section class="page-hero">
    <MetaLabel label="blog" />
    <h1 class="page-title">Notes without a publishing treadmill.</h1>
    <p class="page-subtitle">
      Case studies, migrations, technical decisions and lessons worth writing
      down.
    </p>
  </section>

  <Section title="Posts" accent="published">
    <BlogList posts={posts} emptyMessage="No posts have been published yet." />
  </Section>
</BaseLayout>
