---
import MetaLabel from "@components/MetaLabel.astro";
import Section from "@components/Section.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const locale = "en";
---

<BaseLayout
  title="The Arkenstone — pablesite.es"
  description="The Arkenstone, formerly MoneyPlanner: an open-core personal finance system built from a real need."
  locale={locale}
  path="arkenstone/"
>
  <a class="back-link" href="/en/">← pablesite.es</a>

  <section class="page-hero">
    <MetaLabel label="the arkenstone" />
    <h1 class="page-title">
      Personal finance <span class="highlight">without fighting the tool</span>
    </h1>
    <p class="page-subtitle">
      The Arkenstone is the new name for MoneyPlanner: a system for net worth,
      budgeting, accounting and financial decisions.
    </p>
  </section>

  <Section title="Origin" accent="real problem">
    <div class="prose">
      <p>
        It started from my own need. Existing tools did not match how I manage
        money, so I built a spreadsheet that became more and more sophisticated.
        It worked for a while; then it became fragile, manual and dependent on
        scattered integrations.
      </p>
      <p>
        The Arkenstone turns that system into a product: a clearer base to know
        where you are, decide what to do with your money and reduce the
        operational noise of personal finance.
      </p>
    </div>
  </Section>

  <Section title="Product" accent="open core">
    <div class="grid grid--two">
      <article class="card card--accent-green">
        <h3 class="card__title">Self-hostable core</h3>
        <p class="card__text">
          The core will be free and public for anyone who wants to run an
          instance, inspect the model or adapt it.
        </p>
      </article>
      <article class="card card--accent-blue">
        <h3 class="card__title">Managed SaaS</h3>
        <p class="card__text">
          A managed version runs on top of the core for people who do not want
          to handle servers, deploys, backups or maintenance.
        </p>
      </article>
    </div>
  </Section>

  <Section title="What it covers" accent="v1">
    <div class="grid grid--two">
      {
        [
          "Net worth",
          "Budgeting",
          "Personal accounting",
          "Financial guide",
        ].map((item) => (
          <article class="card card--accent-purple">
            <h3 class="card__title">{item}</h3>
            <p class="card__text">
              One part of a system designed to turn scattered financial data
              into clearer, reviewable decisions.
            </p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Stack" accent="own product">
    <div class="pill-row">
      {
        ["Django", "Vue", "PostgreSQL", "Docker", "CI/CD", "PWA"].map(
          (item) => <span class="pill">{item}</span>,
        )
      }
    </div>
    <div class="contact-box">
      <p>If The Arkenstone sounds interesting, let’s talk.</p>
      <div class="contact-links">
        <a class="direct-link" href={site.email}>Email</a>
        <a class="direct-link" href={site.links.linkedin}>LinkedIn</a>
      </div>
    </div>
  </Section>
</BaseLayout>
