---
import BlogList from "@components/BlogList.astro";
import Icon from "@components/Icon.astro";
import ProjectCard from "@components/ProjectCard.astro";
import Section from "@components/Section.astro";
import ServiceGlyph from "@components/ServiceGlyph.astro";
import { getLatestBlogPosts } from "@data/blog";
import BaseLayout from "@layouts/BaseLayout.astro";
import { ardaServices, copy, outside, projects } from "@data/content";
import { site } from "@data/site";

const locale = "en";
const t = copy[locale];
const featuredServices = ardaServices.slice(0, 8);
const latestBlogPosts = await getLatestBlogPosts(locale);
---

<BaseLayout
  title="pablesite.es — Pablo Ruiz"
  description={t.home.description}
  locale={locale}
>
  <section class="hero">
    <h1 class="hero__title">{t.home.title}</h1>
    <p class="hero__subtitle">
      Same mindset, different team: building my own
      <span class="highlight">personal finance system</span> and a
      <span class="highlight">homelab</span> from scratch.
    </p>
    <div class="hero-links">
      <a class="hero-link hero-link--primary" href={site.links.github}>GitHub</a
      >
      <a class="hero-link hero-link--primary" href={site.links.linkedin}
        >LinkedIn</a
      >
      <a class="hero-link hero-link--primary" href={site.links.x}>X</a>
      <a class="hero-link hero-link--primary" href={site.email}>Email</a>
    </div>
  </section>

  <Section title={t.labels.about} accent={t.labels.aboutAccent}>
    <div class="prose">
      {t.home.about.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="now-box">
      <strong>Right now</strong>
      {t.home.now.replace("Right now ", "")}
    </div>
  </Section>

  <Section
    title={t.labels.projects}
    accent={t.labels.projectsAccent}
    actionHref={site.links.github}
    actionLabel="see GitHub →"
  >
    <div class="grid grid--two">
      {
        projects[locale].map((project) => (
          <ProjectCard
            name={project.name}
            description={project.description}
            href={project.href}
            accent={project.accent}
            stack={project.stack}
            linkLabel="View project"
          />
        ))
      }
    </div>
  </Section>

  <Section
    title={t.labels.arda}
    accent={t.labels.ardaAccent}
    actionHref="/en/arda/"
    actionLabel="/arda →"
  >
    <div class="teaser">
      <p class="teaser__description">
        An old desktop PC from storage, now converted into my home server:
        Debian, Docker and Traefik. Every service has a Tolkien-inspired name.
      </p>
      <div class="compact-grid">
        {
          featuredServices.map((service) => (
            <article
              class={`compact-service ${service.status === "up" ? "compact-service--live" : ""}`}
            >
              <div class="compact-service__brand">
                <ServiceGlyph icon={service.icon} compact />
                {"url" in service && service.url ? (
                  <a
                    class="compact-service__name compact-service__name--link"
                    href={service.url}
                    rel="noreferrer"
                    target="_blank"
                  >
                    {service.name}
                  </a>
                ) : (
                  <h3 class="compact-service__name">{service.name}</h3>
                )}
              </div>
              <p class="compact-service__description">
                {service.description[locale]}
              </p>
              <span
                class={`tag ${service.kind === "own" ? "tag--green" : "tag--blue"}`}
              >
                {typeof service.technology === "string"
                  ? service.technology
                  : service.technology[locale]}
              </span>
            </article>
          ))
        }
      </div>
      <a class="text-link" href="/en/arda/">See all services →</a>
    </div>
  </Section>

  <Section
    title={t.labels.arkenstone}
    accent={t.labels.arkenstoneAccent}
    actionHref="/en/arkenstone/"
    actionLabel="/arkenstone →"
  >
    <div class="teaser">
      <p class="teaser__description">
        I started building it because existing tools did not match how I manage
        money, and my spreadsheet became too complex. Today it is a functional
        open-core system: a free self-hostable core and a managed version for
        people who prefer not to run it themselves.
      </p>
      <div class="ark-feature-row">
        {
          ["Net worth", "Budgeting", "Accounting", "Financial guide"].map(
            (item) => <span class="pill tag--green">{item}</span>,
          )
        }
      </div>
      <div class="ark-stack-row">
        {
          ["Django", "Vue", "PostgreSQL", "Docker", "CI/CD"].map((item) => (
            <span class="pill">{item}</span>
          ))
        }
      </div>
      <a class="text-link" href="/en/arkenstone/">Read more →</a>
    </div>
  </Section>

  <Section
    title={t.labels.blog}
    accent={t.labels.blogAccent}
    actionHref="/en/blog/"
    actionLabel="/blog →"
  >
    <BlogList
      posts={latestBlogPosts}
      emptyMessage="No posts have been published yet."
    />
  </Section>

  <Section title={t.labels.outside} accent={t.labels.outsideAccent}>
    <div class="grid grid--three">
      {
        outside[locale].map((item) => (
          <article class="outside-card">
            <Icon name={item.icon} />
            <div class="outside-card__label">{item.label}</div>
            <h3 class="outside-card__title">{item.main}</h3>
            <p class="outside-card__text">{item.sub}</p>
            {item.href && (
              <a class="text-link" href={item.href}>
                View profile →
              </a>
            )}
          </article>
        ))
      }
    </div>
  </Section>

  <Section title={t.labels.contact}>
    <div class="contact-box">
      <p>Shall we talk?</p>
      <div class="contact-links">
        <a class="direct-link" href={site.email}>Email</a>
        <a class="direct-link" href={site.links.linkedin}>LinkedIn</a>
        <a class="direct-link" href="/en/contact/">Contact →</a>
      </div>
    </div>
  </Section>
</BaseLayout>
