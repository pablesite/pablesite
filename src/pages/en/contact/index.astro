---
import MetaLabel from "@components/MetaLabel.astro";
import Section from "@components/Section.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const locale = "en";
---

<BaseLayout
  title="Contact — pablesite.es"
  description="Contact Pablo Ruiz directly by email or LinkedIn."
  locale={locale}
  path="contact/"
>
  <a class="back-link" href="/en/">← pablesite.es</a>
  <section class="page-hero">
    <MetaLabel label="contact" />
    <h1 class="page-title">Shall we talk?</h1>
    <p class="page-subtitle">
      Write to me if you want to comment on anything or if you have any
      questions.
    </p>
  </section>

  <Section title="Channels" accent="direct">
    <div class="contact-box">
      <p>
        Email for the long version. LinkedIn for the socially acceptable form of
        “hey”.
      </p>
      <div class="contact-links">
        <a class="direct-link" href={site.email}>Email</a>
        <a class="direct-link" href={site.links.linkedin}>LinkedIn</a>
      </div>
    </div>
  </Section>
</BaseLayout>
