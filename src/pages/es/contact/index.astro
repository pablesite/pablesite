---
import MetaLabel from "@components/MetaLabel.astro";
import Section from "@components/Section.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const locale = "es";
---

<BaseLayout
  title="Contacto — pablesite.es"
  description="Contacto directo con Pablo Ruiz por email o LinkedIn."
  locale={locale}
  path="contact/"
>
  <a class="back-link" href="/es/">← pablesite.es</a>
  <section class="page-hero">
    <MetaLabel label="contacto" />
    <h1 class="page-title">¿Hablamos?</h1>
    <p class="page-subtitle">
      Puedes escribirme directamente por email o LinkedIn. El formulario llegará
      cuando tenga sentido añadir una integración segura.
    </p>
  </section>

  <Section title="Canales" accent="directos">
    <div class="contact-box">
      <p>
        Para oportunidades profesionales, colaboración o preguntas sobre The
        Arkenstone y Arda.
      </p>
      <div class="contact-links">
        <a class="direct-link" href={site.email}>Email</a>
        <a class="direct-link" href={site.links.linkedin}>LinkedIn</a>
        <a class="direct-link" href={site.links.github}>GitHub</a>
      </div>
    </div>
    <div class="form-note">
      El diseño original incluía formulario, pero la v1 evita backend y
      proveedores externos para no introducir secretos ni dependencia operativa
      antes de tiempo.
    </div>
  </Section>
</BaseLayout>
